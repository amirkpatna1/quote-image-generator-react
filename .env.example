# Copy this file to .env and fill in real values where needed.
# Most features work without any keys — see notes below.

# Unsplash — get a free key at https://unsplash.com/developers
# Without a real key, the app falls back to Picsum Photos automatically
VITE_UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Google Fonts API — optional; the embed URL approach works without a key
# https://developers.google.com/fonts/docs/developer_api
VITE_GOOGLE_FONTS_API_KEY=your_google_fonts_api_key_here

# Anthropic Claude API — for AI quote generation and AI background features
# https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe — Freemium payments (UI only, backend not implemented)
# https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Buffer — Social media scheduling (UI only; saves to localStorage)
# https://buffer.com/developers/api
VITE_BUFFER_API_KEY=your_buffer_api_key_here

# Supabase — Team workspaces (UI only; saves to localStorage)
# https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
